{
  "name": "profilepilot",
  "version": "0.1.0",
  "description": "A local desktop control desk for managing Chrome profiles and extensions.",
  "homepage": "https://ffffhx.github.io/profilepilot/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ffffhx/profilepilot.git"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "build": "npm run build:input-guard && tsc && npm run bundle:browser-wrappers && npm run bundle:renderer && npm run build:css",
    "build:input-guard": "node scripts/build-input-guard.mjs",
    "setup:input-guard-signing": "node scripts/setup-input-guard-signing.mjs",
    "bundle:agent-browser-wrapper": "esbuild src/main/agent-browser-wrapper.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/main/profilepilot-agent-browser-wrapper.cjs --log-level=warning",
    "bundle:playwright-cli-wrapper": "esbuild src/main/playwright-cli-wrapper.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/main/profilepilot-playwright-cli-wrapper.cjs --log-level=warning",
    "bundle:chrome-devtools-mcp-wrapper": "esbuild src/main/chrome-devtools-mcp-wrapper.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/main/profilepilot-chrome-devtools-mcp-wrapper.cjs --log-level=warning",
    "bundle:browser-wrappers": "npm run bundle:agent-browser-wrapper && npm run bundle:playwright-cli-wrapper && npm run bundle:chrome-devtools-mcp-wrapper",
    "bundle:renderer": "esbuild src/renderer/main.ts --bundle --outfile=dist/renderer/app.js --platform=browser --format=iife --target=es2022 --log-level=warning",
    "build:css": "tailwindcss -i ./public/styles.src.css -o ./public/app.css",
    "watch:css": "tailwindcss -i ./public/styles.src.css -o ./public/app.css --watch",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "check": "tsc --noEmit",
    "pack": "npm run build && electron-builder --dir --publish never",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --arm64 --x64 --publish never",
    "dist:mac:arm64": "npm run build && electron-builder --mac dmg zip --arm64 --publish never",
    "dist:mac:x64": "npm run build && electron-builder --mac dmg zip --x64 --publish never",
    "dist:win": "npm run build && electron-builder --win nsis zip --x64 --publish never",
    "site": "node site/server.mjs",
    "test": "npm run build && node --test tests/",
    "doctor:overlay": "npm run build && node scripts/overlay-doctor.mjs",
    "e2e": "npm run e2e:background",
    "e2e:background": "npm run build && node scripts/e2e-main-window.mjs && node scripts/e2e-background-ui.mjs && node scripts/e2e-sync-copy.mjs && node scripts/e2e-visual-regression.mjs && node scripts/e2e-overlay-smoke.mjs",
    "e2e:desktop": "npm run build && node scripts/e2e-desktop-ui.mjs && node scripts/e2e-gateway-control.mjs && node scripts/e2e-mini-window.mjs && node scripts/e2e-input-guard.mjs",
    "e2e:full": "npm run e2e:background && npm run e2e:desktop",
    "e2e:main-window": "npm run build && node scripts/e2e-main-window.mjs",
    "e2e:desktop-ui": "npm run build && node scripts/e2e-desktop-ui.mjs",
    "e2e:mini": "npm run build && node scripts/e2e-mini-window.mjs",
    "e2e:visual": "npm run build && node scripts/e2e-visual-regression.mjs",
    "e2e:visual:update": "npm run build && UPDATE_VISUAL_BASELINES=1 node scripts/e2e-visual-regression.mjs",
    "e2e:sync-copy": "npm run build && node scripts/e2e-sync-copy.mjs",
    "e2e:gateway": "npm run build && node scripts/e2e-gateway-control.mjs",
    "e2e:browser-drivers": "npm run build && node scripts/e2e-browser-drivers.mjs",
    "e2e:input-guard": "npm run build && node scripts/e2e-input-guard.mjs",
    "e2e:overlay": "npm run build && node scripts/e2e-overlay-smoke.mjs",
    "e2e:stress": "npm run build && node scripts/e2e-overlay-stress.mjs",
    "verify:overlay": "node scripts/verify-overlay.mjs",
    "bench": "npm run build && node scripts/bench-overlay.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "ffffhx",
  "license": "MIT",
  "build": {
    "appId": "io.github.ffffhx.profilepilot",
    "productName": "ProfilePilot",
    "copyright": "Copyright 2026 ffffhx",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/native/**/*",
      "public/**/*",
      "README.md",
      "LICENSE",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/native/ProfilePilot Input Guard.app",
        "to": "native/ProfilePilot Input Guard.app"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "ProfilePilot-mac-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "ProfilePilot-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ProfilePilot-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ProfilePilot",
      "artifactName": "ProfilePilot-win-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ffffhx",
        "repo": "profilepilot"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  }
}
